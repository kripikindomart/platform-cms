# Application
NODE_ENV=development
APP_PORT=3000
APP_NAME=Platform CMS
APP_URL=http://localhost:3000
API_PREFIX=/api

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=platform_cms
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DB_MAX_CONNECTIONS=20

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=change-this-in-production-use-strong-random-string-min-32-chars
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_TTL=60

# Multi-Tenancy
DEFAULT_TENANT_SLUG=tenant_1
BASE_DOMAIN=platform-cms.com
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=http://localhost:3001
CORS_CREDENTIALS=true

# Logging
LOG_LEVEL=debug

# Session
SESSION_SECRET=change-this-in-production-use-strong-random-string-min-32-chars
SESSION_MAX_AGE=86400000

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_DEST=./uploads

# Storage Provider Selection (google-drive | s3 | local)
# - local: Local filesystem (development only)
# - google-drive: Google Drive with OAuth2 or Service Account
# - s3: AWS S3 or S3-compatible (MinIO, DigitalOcean Spaces)
STORAGE_PROVIDER=google-drive

# File Size Limits (in bytes)
MAX_IMAGE_SIZE=5242880
MAX_DOCUMENT_SIZE=10485760

# ===== GOOGLE DRIVE - OAUTH2 (Personal Gmail - RECOMMENDED) =====
# Setup: Run `node scripts/setup-google-oauth.js`
# 1. Create OAuth Client: https://console.cloud.google.com/apis/credentials
# 2. Enable Google Drive API
# 3. Add redirect: http://localhost:3333/oauth2callback
# 4. Run setup script
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# ===== GOOGLE DRIVE - CONFIGURATION =====
# Folder ID (optional, uses My Drive root if empty)
# Create folder: Run `node scripts/create-app-folder.js`
GOOGLE_DRIVE_FOLDER_ID=
# Make files public (true/false)
GOOGLE_DRIVE_MAKE_PUBLIC=true

# ===== GOOGLE DRIVE - SERVICE ACCOUNT (Google Workspace Only) =====
# Path to JSON credentials file
GOOGLE_DRIVE_CREDENTIALS_PATH=./google-drive-credentials.json
# Or inline JSON string
GOOGLE_DRIVE_CREDENTIALS=

# ===== AWS S3 / MINIO / DIGITALOCEAN SPACES =====
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
# For MinIO/DigitalOcean Spaces
AWS_S3_ENDPOINT=
AWS_S3_PUBLIC_URL=
AWS_S3_FORCE_PATH_STYLE=false
