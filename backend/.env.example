# Application
NODE_ENV=development
APP_PORT=3000
APP_NAME=Platform CMS
APP_URL=http://localhost:3000
API_PREFIX=/api

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=platform_cms
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DB_MAX_CONNECTIONS=20

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=change-this-in-production-use-strong-random-string-min-32-chars
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_TTL=60

# Multi-Tenancy
DEFAULT_TENANT_SLUG=tenant_1
BASE_DOMAIN=platform-cms.com
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=http://localhost:3001
CORS_CREDENTIALS=true

# Logging
LOG_LEVEL=debug

# Session
SESSION_SECRET=change-this-in-production-use-strong-random-string-min-32-chars
SESSION_MAX_AGE=86400000

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DEST=./uploads
