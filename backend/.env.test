NODE_ENV=test
APP_PORT=3001
APP_NAME=Platform CMS Test
APP_URL=http://localhost:3001
API_PREFIX=/api

DB_HOST=localhost
DB_PORT=5432
DB_NAME=platform_cms_test
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DB_MAX_CONNECTIONS=10

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1

JWT_SECRET=test-secret-key-minimum-32-characters-long-for-testing-only
JWT_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=24h

BCRYPT_ROUNDS=4
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

CORS_ORIGIN=http://localhost:3001
CORS_CREDENTIALS=true

LOG_LEVEL=error

SESSION_SECRET=test-session-secret-minimum-32-characters-long-for-testing
SESSION_MAX_AGE=3600000

MAX_FILE_SIZE=1048576
UPLOAD_DEST=./test-uploads
