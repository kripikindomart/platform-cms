'use client';

import { useEffect, useState } from 'react';
import { useParams } from 'next/navigation';
import { useForm } from 'react-hook-form';
import { zodResolver } from '@hookform/resolvers/zod';
import { z } from 'zod';
import { toast } from 'sonner';
import { ArrowLeft } from 'lucide-react';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { Form, FormField, FormItem, FormLabel, FormControl, FormMessage } from '@/components/ui/form';
import { Input } from '@/components/ui/input';
import { Textarea } from '@/components/ui/textarea';
import { Switch } from '@/components/ui/switch';
import { Select } from '@/components/ui/select';
import { Button } from '@/components/ui/button';
import { Skeleton } from '@/components/ui/skeleton';
import { usePortalRouter } from '@/hooks/use-portal-router';
import { {{toCamelCase moduleName}}Service } from '@/lib/api/services/{{moduleName}}.service';

const formSchema = z.object({
{{#each fields}}
{{#if (eq type "boolean")}}
  {{camelCase}}: z.boolean(),
{{else}}
  {{camelCase}}: z.string(){{#if isRequired}}.min(1, '{{label}} wajib diisi'){{else}}.optional(){{/if}},
{{/if}}
{{/each}}
});

type FormData = z.infer<typeof formSchema>;

/**
 * Edit {{displayName}} Page
 * @generated
 */
export default function Edit{{className}}Page() {
  const params = useParams();
  const { push } = usePortalRouter();
  const id = Number(params.id);

  const [loading, setLoading] = useState(true);

  const form = useForm<FormData>({
    resolver: zodResolver(formSchema),
    defaultValues: {
{{#each fields}}
{{#if (eq type "boolean")}}
      {{camelCase}}: false,
{{else}}
      {{camelCase}}: '',
{{/if}}
{{/each}}
    },
  });

  useEffect(() => {
    const load = async () => {
      setLoading(true);
      try {
        const item = await {{toCamelCase moduleName}}Service.getById(id);
        form.reset({
{{#each fields}}
{{#if (eq type "boolean")}}
          {{camelCase}}: item.{{camelCase}} ?? false,
{{else if (eq type "number")}}
          {{camelCase}}: item.{{camelCase}} != null ? String(item.{{camelCase}}) : '',
{{else}}
          {{camelCase}}: item.{{camelCase}} ?? '',
{{/if}}
{{/each}}
        });
      } catch (error) {
        toast.error('Gagal memuat data {{displayName}}');
        push('{{moduleName}}');
      } finally {
        setLoading(false);
      }
    };
    load();
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [id]);

  const onSubmit = async (data: FormData) => {
    try {
      const payload = {
        ...data,
{{#each fields}}
{{#if (eq type "number")}}
        {{camelCase}}: data.{{camelCase}} === '' ? undefined : Number(data.{{camelCase}}),
{{/if}}
{{/each}}
      };
      await {{toCamelCase moduleName}}Service.update(id, payload as any);
      toast.success('{{displayName}} berhasil diperbarui');
      push('{{moduleName}}');
    } catch (error) {
      toast.error(error instanceof Error ? error.message : 'Gagal memperbarui {{displayName}}');
    }
  };

  if (loading) {
    return (
      <div className="max-w-3xl mx-auto space-y-6">
        <Skeleton className="h-8 w-32" />
        <Skeleton className="h-64 w-full" />
      </div>
    );
  }

  return (
    <div className="max-w-3xl mx-auto space-y-6">
      <Button variant="ghost" onClick={() => push('{{moduleName}}')} className="-ml-3">
        <ArrowLeft className="mr-2 h-4 w-4" />
        Kembali
      </Button>

      <h1 className="text-3xl font-bold text-neutral-900">Edit {{displayName}}</h1>

      <Form {...form}>
        <form onSubmit={form.handleSubmit(onSubmit)} className="space-y-6">
          <Card className="rounded-2xl border-neutral-100 shadow-sm">
            <CardHeader>
              <CardTitle>Informasi {{displayName}}</CardTitle>
            </CardHeader>
            <CardContent className="space-y-4">
{{#each fields}}
              <FormField
                control={form.control}
                name="{{camelCase}}"
                render={({ field }) => (
                  <FormItem>
                    <FormLabel>{{label}}{{#if isRequired}} *{{/if}}</FormLabel>
                    <FormControl>
{{#if (eq type "text")}}
                      <Textarea rows={4} {...field} />
{{else if (eq type "json")}}
                      <Textarea rows={4} placeholder="{}" {...field} />
{{else if (eq type "boolean")}}
                      <Switch checked={field.value} onCheckedChange={field.onChange} />
{{else if (eq type "date")}}
                      <Input type="date" {...field} value={field.value ?? ''} />
{{else if (eq type "datetime")}}
                      <Input type="datetime-local" {...field} value={field.value ?? ''} />
{{else if (eq type "number")}}
                      <Input type="number" {...field} value={field.value ?? ''} />
{{else if (eq type "email")}}
                      <Input type="email" {...field} />
{{else if (eq type "url")}}
                      <Input type="url" {...field} />
{{else if (eq type "enum")}}
                      <Select
                        {...field}
                        options={[
{{#each enumOptions}}
                          { value: '{{this}}', label: '{{this}}' },
{{/each}}
                        ]}
                      />
{{else}}
                      <Input type="text" {...field} />
{{/if}}
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
{{/each}}
            </CardContent>
          </Card>

          <div className="flex justify-end gap-2">
            <Button type="button" variant="outline" onClick={() => push('{{moduleName}}')}>
              Batal
            </Button>
            <Button
              type="submit"
              disabled={form.formState.isSubmitting}
              className="bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 text-white"
            >
              {form.formState.isSubmitting ? 'Menyimpan...' : 'Simpan'}
            </Button>
          </div>
        </form>
      </Form>
    </div>
  );
}
