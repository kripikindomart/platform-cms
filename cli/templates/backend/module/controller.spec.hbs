import { Test, TestingModule } from '@nestjs/testing';
import { INestApplication } from '@nestjs/common';
import * as request from 'supertest';
import { {{pascalCase name}}Controller } from './{{kebabCase name}}.controller';
import { {{pascalCase name}}Service } from './{{kebabCase name}}.service';
import { JwtAuthGuard } from '../auth/guards/jwt-auth.guard';
import { TenantGuard } from '../../common/guards/tenant.guard';
import { CaslGuard } from '../../core/casl/casl.guard';

describe('{{pascalCase name}}Controller', () => {
  let app: INestApplication;
  let service: {{pascalCase name}}Service;

  const mock{{pascalCase name}}Service = {
    findAll: jest.fn(),
    findById: jest.fn(),
    create: jest.fn(),
    update: jest.fn(),
    delete: jest.fn(),
    findAllWithQuery: jest.fn(),
  };

  beforeEach(async () => {
    const module: TestingModule = await Test.createTestingModule({
      controllers: [{{pascalCase name}}Controller],
      providers: [
        {
          provide: {{pascalCase name}}Service,
          useValue: mock{{pascalCase name}}Service,
        },
      ],
    })
      .overrideGuard(JwtAuthGuard)
      .useValue({ canActivate: jest.fn(() => true) })
      .overrideGuard(TenantGuard)
      .useValue({ canActivate: jest.fn(() => true) })
      .overrideGuard(CaslGuard)
      .useValue({ canActivate: jest.fn(() => true) })
      .compile();

    app = module.createNestApplication();
    await app.init();

    service = module.get<{{pascalCase name}}Service>({{pascalCase name}}Service);
  });

  afterEach(async () => {
    await app.close();
    jest.clearAllMocks();
  });

  describe('GET /{{kebabCase (pluralize name)}}', () => {
    it('harus mengembalikan array {{pluralize name}}', async () => {
      const mockData = [
        { id: 1, {{#each fields}}{{#if @first}}{{this.name}}: 'test 1'{{/if}}{{/each}} },
        { id: 2, {{#each fields}}{{#if @first}}{{this.name}}: 'test 2'{{/if}}{{/each}} },
      ];

      mock{{pascalCase name}}Service.findAllWithQuery.mockResolvedValue({
        data: mockData,
        total: 2,
        page: 1,
        limit: 10,
      });

      const response = await request(app.getHttpServer())
        .get('/{{kebabCase (pluralize name)}}')
        .expect(200);

      expect(response.body.data).toBeDefined();
      expect(Array.isArray(response.body.data.data)).toBe(true);
    });

    it('harus support pagination', async () => {
      mock{{pascalCase name}}Service.findAllWithQuery.mockResolvedValue({
        data: [],
        total: 0,
        page: 2,
        limit: 5,
      });

      await request(app.getHttpServer())
        .get('/{{kebabCase (pluralize name)}}?page=2&limit=5')
        .expect(200);

      expect(service.findAllWithQuery).toHaveBeenCalledWith(
        expect.objectContaining({
          page: 2,
          limit: 5,
        }),
      );
    });
  });

  describe('GET /{{kebabCase (pluralize name)}}/:id', () => {
    it('harus mengembalikan {{singularize name}} berdasarkan ID', async () => {
      const mockData = {
        id: 1,
        {{#each fields}}{{#if @first}}{{this.name}}: 'test'{{/if}}{{/each}},
      };

      mock{{pascalCase name}}Service.findById.mockResolvedValue(mockData);

      const response = await request(app.getHttpServer())
        .get('/{{kebabCase (pluralize name)}}/1')
        .expect(200);

      expect(response.body.data).toEqual(mockData);
      expect(service.findById).toHaveBeenCalledWith(1);
    });

    it('harus return 404 jika tidak ditemukan', async () => {
      mock{{pascalCase name}}Service.findById.mockRejectedValue(
        new Error('Not found'),
      );

      await request(app.getHttpServer())
        .get('/{{kebabCase (pluralize name)}}/999')
        .expect(404);
    });
  });

  describe('POST /{{kebabCase (pluralize name)}}', () => {
    it('harus membuat {{singularize name}} baru', async () => {
      const createDto = {
        {{#each fields}}{{#if @first}}{{this.name}}: 'test'{{/if}}{{/each}},
      };

      const mockCreated = {
        id: 1,
        ...createDto,
      };

      mock{{pascalCase name}}Service.create.mockResolvedValue(mockCreated);

      const response = await request(app.getHttpServer())
        .post('/{{kebabCase (pluralize name)}}')
        .send(createDto)
        .expect(201);

      expect(response.body.data).toEqual(mockCreated);
      expect(service.create).toHaveBeenCalled();
    });

    it('harus return 400 jika data tidak valid', async () => {
      const invalidDto = {};

      await request(app.getHttpServer())
        .post('/{{kebabCase (pluralize name)}}')
        .send(invalidDto)
        .expect(400);
    });
  });

  describe('PATCH /{{kebabCase (pluralize name)}}/:id', () => {
    it('harus mengupdate {{singularize name}} yang ada', async () => {
      const updateDto = {
        {{#each fields}}{{#if @first}}{{this.name}}: 'updated'{{/if}}{{/each}},
      };

      const mockUpdated = {
        id: 1,
        ...updateDto,
      };

      mock{{pascalCase name}}Service.update.mockResolvedValue(mockUpdated);

      const response = await request(app.getHttpServer())
        .patch('/{{kebabCase (pluralize name)}}/1')
        .send(updateDto)
        .expect(200);

      expect(response.body.data).toEqual(mockUpdated);
      expect(service.update).toHaveBeenCalledWith(1, updateDto, undefined);
    });

    it('harus return 404 jika ID tidak ditemukan', async () => {
      mock{{pascalCase name}}Service.update.mockRejectedValue(
        new Error('Not found'),
      );

      await request(app.getHttpServer())
        .patch('/{{kebabCase (pluralize name)}}/999')
        .send({ {{#each fields}}{{#if @first}}{{this.name}}: 'test'{{/if}}{{/each}} })
        .expect(404);
    });
  });

  describe('DELETE /{{kebabCase (pluralize name)}}/:id', () => {
    it('harus soft delete {{singularize name}}', async () => {
      mock{{pascalCase name}}Service.delete.mockResolvedValue(undefined);

      await request(app.getHttpServer())
        .delete('/{{kebabCase (pluralize name)}}/1')
        .expect(200);

      expect(service.delete).toHaveBeenCalledWith(1, undefined);
    });

    it('harus return 404 jika ID tidak ditemukan', async () => {
      mock{{pascalCase name}}Service.delete.mockRejectedValue(
        new Error('Not found'),
      );

      await request(app.getHttpServer())
        .delete('/{{kebabCase (pluralize name)}}/999')
        .expect(404);
    });
  });
});
