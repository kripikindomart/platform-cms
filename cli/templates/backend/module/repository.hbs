import { Injectable, Inject } from '@nestjs/common';
{{#if softDelete}}
import { BaseRepository } from '../../common/database/base.repository';
{{/if}}
{{#if tenant}}
import { TenantContextService } from '../../common/context/tenant-context.service';
{{/if}}
import { NodePgDatabase } from 'drizzle-orm/node-postgres';
import { eq } from 'drizzle-orm';
import * as tenantSchema from '../../database/schema/tenant';
{{#if useExistingSchema}}
import { {{camelCase (pluralize name)}} } from '../../database/schema/tenant/{{kebab-case (pluralize name)}}.schema';
{{else}}
import { {{camelCase (pluralize name)}} } from './entities/{{kebab-case (singularize name)}}.entity';
{{/if}}

{{#if softDelete}}
@Injectable()
export class {{PascalCase name}}Repository extends BaseRepository<typeof {{camelCase (pluralize name)}}.$inferSelect> {
  constructor(
    @Inject('DRIZZLE') db: NodePgDatabase<typeof tenantSchema>,
    {{#if tenant}}
    tenantContext: TenantContextService,
    {{/if}}
  ) {
    super(
      db,
      {{camelCase (pluralize name)}},
      {{#if tenant}}tenantContext{{else}}null{{/if}},
    );
  }

  /**
   * Find all with pagination, filtering, sorting, and search
   */
  async findAllWithQuery(query: any): Promise<{
    data: (typeof {{camelCase (pluralize name)}}.$inferSelect)[];
    total: number;
    page: number;
    limit: number;
  }> {
    const { page = 1, limit = 10, sort, order = 'asc', search } = query;
    const offset = (page - 1) * limit;

    {{#if tenant}}
    return this.withTenantSchema(async () => {
    {{/if}}
      const { and, or, eq, ilike, isNull, sql, asc, desc } = await import('drizzle-orm');
      
      // Build WHERE conditions
      const conditions: any[] = [isNull(this.table.deleted_at)];
      
      {{#if (hasFilterable fields)}}
      // Apply filters
      {{#each fields}}
      {{#if this.isFilterable}}
      if (query.{{this.name}} !== undefined) {
        {{#if (eq this.type 'number')}}
        if (query.{{this.name}} === null) {
          conditions.push(isNull(this.table.{{this.name}}));
        } else {
          conditions.push(eq(this.table.{{this.name}}, query.{{this.name}}));
        }
        {{else}}
        conditions.push(eq(this.table.{{this.name}}, query.{{this.name}}));
        {{/if}}
      }
      {{/if}}
      {{/each}}
      {{/if}}

      {{#if (hasSearchable fields)}}
      // Apply search (case-insensitive)
      if (search) {
        const searchConditions = [
          {{#each fields}}
          {{#if this.isSearchable}}
          ilike(this.table.{{this.name}}, `%${search}%`),
          {{/if}}
          {{/each}}
        ];
        if (searchConditions.length > 0) {
          conditions.push(or(...searchConditions)!);
        }
      }
      {{/if}}

      const whereClause = and(...conditions);

      // Get total count
      const countResult = await this.db
        .select({ count: sql<number>`count(*)::int` })
        .from(this.table)
        .where(whereClause);
      const total = Number(countResult[0]?.count || 0);

      // Build main query
      let dbQuery: any = this.db
        .select()
        .from(this.table)
        .where(whereClause);

      {{#if (hasSortable fields)}}
      // Apply sorting
      const sortField = sort || 'created_at';
      if (order === 'desc') {
        dbQuery = dbQuery.orderBy(desc(this.table[sortField]));
      } else {
        dbQuery = dbQuery.orderBy(asc(this.table[sortField]));
      }
      {{/if}}

      // Apply pagination
      const data = await dbQuery.limit(limit).offset(offset);

      return {
        data,
        total,
        page,
        limit,
      };
    {{#if tenant}}
    });
    {{/if}}
  }

  // Add custom query methods here
}
{{else}}
@Injectable()
export class {{PascalCase name}}Repository {
  constructor(
    @Inject('DRIZZLE') private readonly db: NodePgDatabase<typeof tenantSchema>,
    {{#if tenant}}
    private readonly tenantContext: TenantContextService,
    {{/if}}
  ) {}

  {{#if tenant}}
  /**
   * Execute query within tenant schema
   */
  private async withTenantSchema<T>(callback: () => Promise<T>): Promise<T> {
    const schemaName = this.tenantContext.getSchemaName();
    await this.db.execute(`SET search_path TO ${schemaName}, public`);
    try {
      return await callback();
    } finally {
      await this.db.execute('SET search_path TO public');
    }
  }
  {{/if}}

  /**
   * Find all {{pluralize (lowercase name)}}
   */
  async findAll(): Promise<(typeof {{camelCase (pluralize name)}}.$inferSelect)[]> {
    {{#if tenant}}
    return this.withTenantSchema(async () => {
      return this.db.select().from({{camelCase (pluralize name)}});
    });
    {{else}}
    return this.db.select().from({{camelCase (pluralize name)}});
    {{/if}}
  }

  /**
   * Find {{singularize (lowercase name)}} by ID
   */
  async findById(id: number): Promise<typeof {{camelCase (pluralize name)}}.$inferSelect | null> {
    {{#if tenant}}
    return this.withTenantSchema(async () => {
      const result = await this.db
        .select()
        .from({{camelCase (pluralize name)}})
        .where(eq({{camelCase (pluralize name)}}.id, id))
        .limit(1);
      return result[0] || null;
    });
    {{else}}
    const result = await this.db
      .select()
      .from({{camelCase (pluralize name)}})
      .where(eq({{camelCase (pluralize name)}}.id, id))
      .limit(1);
    return result[0] || null;
    {{/if}}
  }

  /**
   * Create {{singularize (lowercase name)}}
   */
  async create(data: typeof {{camelCase (pluralize name)}}.$inferInsert): Promise<typeof {{camelCase (pluralize name)}}.$inferSelect> {
    {{#if tenant}}
    return this.withTenantSchema(async () => {
      const result = await this.db.insert({{camelCase (pluralize name)}}).values(data).returning();
      return result[0];
    });
    {{else}}
    const result = await this.db.insert({{camelCase (pluralize name)}}).values(data).returning();
    return result[0];
    {{/if}}
  }

  /**
   * Update {{singularize (lowercase name)}}
   */
  async update(id: number, data: Partial<typeof {{camelCase (pluralize name)}}.$inferInsert>): Promise<typeof {{camelCase (pluralize name)}}.$inferSelect> {
    {{#if tenant}}
    return this.withTenantSchema(async () => {
      const result = await this.db
        .update({{camelCase (pluralize name)}})
        .set({ ...data, updated_at: new Date() })
        .where(eq({{camelCase (pluralize name)}}.id, id))
        .returning();
      return result[0];
    });
    {{else}}
    const result = await this.db
      .update({{camelCase (pluralize name)}})
      .set({ ...data, updated_at: new Date() })
      .where(eq({{camelCase (pluralize name)}}.id, id))
      .returning();
    return result[0];
    {{/if}}
  }

  /**
   * Hard delete {{singularize (lowercase name)}}
   */
  async hardDelete(id: number): Promise<void> {
    {{#if tenant}}
    await this.withTenantSchema(async () => {
      await this.db.delete({{camelCase (pluralize name)}}).where(eq({{camelCase (pluralize name)}}.id, id));
    });
    {{else}}
    await this.db.delete({{camelCase (pluralize name)}}).where(eq({{camelCase (pluralize name)}}.id, id));
    {{/if}}
  }

  /**
   * Find all with pagination, filtering, sorting
   */
  async findAllWithQuery(query: any): Promise<{
    data: (typeof {{camelCase (pluralize name)}}.$inferSelect)[];
    total: number;
    page: number;
    limit: number;
    totalPages: number;
  }> {
    const { page = 1, limit = 10, sort, order = 'asc', search } = query;
    const offset = (page - 1) * limit;
    
    {{#if tenant}}
    return this.withTenantSchema(async () => {
    {{/if}}
      const { and, or, eq, ilike, isNull, sql, asc, desc } = await import('drizzle-orm');
      
      // Build WHERE conditions
      const conditions: any[] = [
        {{#if softDelete}}
        isNull({{camelCase (pluralize name)}}.deleted_at),
        {{/if}}
      ];
      
      {{#if (hasFilterable fields)}}
      // Apply filters
      {{#each fields}}
      {{#if this.isFilterable}}
      if (query.{{this.name}} !== undefined) {
        conditions.push(eq({{camelCase (pluralize @root.name)}}.{{this.name}}, query.{{this.name}}));
      }
      {{/if}}
      {{/each}}
      {{/if}}

      {{#if (hasSearchable fields)}}
      // Apply search
      if (search) {
        const searchConditions = [
          {{#each fields}}
          {{#if this.isSearchable}}
          ilike({{camelCase (pluralize @root.name)}}.{{this.name}}, `%${search}%`),
          {{/if}}
          {{/each}}
        ];
        if (searchConditions.length > 0) {
          conditions.push(or(...searchConditions));
        }
      }
      {{/if}}

      // Count total
      const whereClause = conditions.length > 0 ? and(...conditions) : undefined;
      const [countResult] = await this.db
        .select({ count: sql<number>`count(*)` })
        .from({{camelCase (pluralize name)}})
        {{#if softDelete}}
        .where(whereClause)
        {{/if}};
      
      const total = Number(countResult.count);

      // Fetch data
      let dbQuery = this.db
        .select()
        .from({{camelCase (pluralize name)}})
        {{#if softDelete}}
        .where(whereClause)
        {{/if}}
        .limit(limit)
        .offset(offset);

      {{#if (hasSortable fields)}}
      // Apply sorting
      if (sort) {
        const sortColumn = {{camelCase (pluralize name)}}[sort as keyof typeof {{camelCase (pluralize name)}}] as any;
        if (sortColumn) {
          if (order === 'desc') {
            dbQuery = dbQuery.orderBy(desc(sortColumn)) as any;
          } else {
            dbQuery = dbQuery.orderBy(asc(sortColumn)) as any;
          }
        }
      }
      {{/if}}

      const data = await dbQuery;

      return {
        data,
        total,
        page,
        limit,
        totalPages: Math.ceil(total / limit),
      };
    {{#if tenant}}
    });
    {{/if}}
  }

  // Add custom query methods here
}
{{/if}}
